{
  "name": "trade-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/src/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "db:init": "python3 python/init_db.py",
    "prisma:migrate": "npm run db:init && npm run prisma:generate",
    "ingest:post-close": "tsx src/jobs/postCloseIngest.ts",
    "export:static-data": "tsx src/jobs/exportStaticData.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.0.4",
    "@prisma/client": "^6.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cron": "^3.1.7",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  }
}
